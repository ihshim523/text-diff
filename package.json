{
  "name": "text-diff",
  "version": "1.0.0",
  "description": "LCS-based text diff algorithm in pure TypeScript — zero dependencies",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
